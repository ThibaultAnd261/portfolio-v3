---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../layouts/Navbar.astro";
import ProjetHero from "../../components/ProjetHero.astro";
import ProjetSidebar from "../../components/ProjetSidebar.astro";

export async function getStaticPaths() {
  const projets = await getCollection("projets");
  return projets.map((projet) => ({
    params: { slug: projet.slug },
    props: { projet },
  }));
}

interface Props {
  projet: CollectionEntry<"projets">;
}

const { projet } = Astro.props;
const { Content } = await projet.render();
const {
  title,
  description,
  objectif,
  image,
  date,
  technos,
  collaborateurs,
  lien,
  github,
  statut,
} = projet.data;
---

<Layout title={`Thibault A. | ${title}`} description={description}>
  <Navbar />
  <main class="projet-page">
    <div class="projet-page__inner">
      <a href="/" class="projet-page__back">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Retour aux projets
      </a>

      <ProjetHero {title} {image} {date} {statut} />

      {objectif && <p class="projet-page__objectif">{objectif}</p>}

      <div class="projet-page__body">
        <article class="projet-page__content prose">
          <Content />
        </article>

        <ProjetSidebar {technos} {collaborateurs} {lien} {github} />
      </div>
    </div>
  </main>
</Layout>

<style>
  .projet-page {
    padding: 2rem 1.5rem 5rem;
  }

  .projet-page__inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .projet-page__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Karla", sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--charcoal);
    text-decoration: none;
    margin-bottom: 2rem;
    padding: 0.5em 1em;
    border-radius: 10px;
    transition: all 0.3s var(--transition-smooth);
  }

  .projet-page__back:hover {
    background: var(--sand);
    color: var(--copper);
  }

  .projet-page__back svg {
    transition: transform 0.3s var(--transition-smooth);
  }

  .projet-page__back:hover svg {
    transform: translateX(-4px);
  }

  .projet-page__objectif {
    font-size: 1.15rem;
    color: var(--charcoal);
    opacity: 0.7;
    line-height: 1.6;
    border-left: 4px solid var(--copper);
    padding-left: 1rem;
    margin: 0 0 3rem;
    font-style: italic;
    font-family: "Karla", sans-serif;
  }

  .projet-page__body {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Prose (contenu Markdown) */
  .prose {
    font-family: "Karla", sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: var(--charcoal);
  }

  .prose :global(h2) {
    font-family: "DM Serif Display", serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--terracotta);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid rgba(26, 22, 20, 0.08); /* charcoal rgba(26, 22, 20, 0.08) */
  }

  .prose :global(h2:first-of-type) {
    margin-top: 0;
  }

  .prose :global(h3) {
    font-family: "DM Serif Display", serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--terracotta);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(a) {
    color: var(--copper);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.3s var(--transition-smooth);
  }

  .prose :global(a:hover) {
    color: var(--terracotta);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    font-weight: 700;
    color: var(--charcoal);
  }

  .prose :global(code) {
    background: var(--sand);
    color: var(--terracotta);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }

  .prose :global(pre) {
    background: var(--charcoal);
    color: var(--cream);
    padding: 1.25rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 0 0 1.25rem;
  }

  .prose :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--copper);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--charcoal);
    opacity: 0.8;
    font-style: italic;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.5rem;
    font-size: 0.9rem;
  }

  .prose :global(thead) {
    border-bottom: 2px solid rgba(26, 22, 20, 0.08); /* charcoal rgba(26, 22, 20, 0.08) */
  }

  .prose :global(th) {
    text-align: left;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--charcoal);
    opacity: 0.5;
    padding: 0.5rem 1rem 0.5rem 0;
  }

  .prose :global(td) {
    padding: 0.55rem 1rem 0.55rem 0;
    vertical-align: top;
    border-bottom: 1px solid rgba(26, 22, 20, 0.08); /* charcoal rgba(26, 22, 20, 0.08) */
  }

  .prose :global(td:first-child) {
    font-weight: 700;
    white-space: nowrap;
    color: var(--terracotta);
    width: 1%;
    padding-right: 2rem;
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .projet-page__body {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .projet-page__content {
      order: 2;
    }

    .projet-page__body > :global(aside) {
      order: 1;
      position: static;
      border-top: none;
      border-bottom: 2px solid rgba(26, 22, 20, 0.08); /* charcoal rgba(26, 22, 20, 0.08) */
      padding-top: 0;
      padding-bottom: 2rem;
    }
  }
</style>
