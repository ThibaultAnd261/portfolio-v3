---
import "@fontsource/dm-serif-display";
import "@fontsource/karla/400.css";
import "@fontsource/karla/600.css";
import "@fontsource/karla/700.css";
import "../styles/color.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Portfolio - Ingénieur Créatif" } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div id="loader" aria-hidden="true">
			<div class="loader-inner">
				<p class="loader-name">
						{["T","h","i","b","a","u","l","t"].map((letter, i) => (
							<span class="loader-letter" style={`animation-delay: ${0.05 + i * 0.08}s`}>{letter}</span>
						))}
					</p>
				<div class="loader-bar-track">
					<div class="loader-bar"></div>
				</div>
			</div>
		</div>
		<slot />
	</body>

	<style is:global>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			font-family: 'Karla', sans-serif;
			background: linear-gradient(135deg, var(--sand) 0%, var(--cream) 100%);
			min-height: 100vh;
			scroll-behavior: smooth;
		}

		body {
			color: var(--charcoal);
			line-height: 1.6;
			padding-bottom: 100px;
		}

		@media (min-width: 1025px) {
			body {
				padding-top: 80px;
				padding-bottom: 80px;
			}
		}

		/* Typography */
		h1, h2, h3, h4 {
			font-family: 'DM Serif Display', serif;
			line-height: 1.1;
		}

		h1 {
			font-size: clamp(2.5rem, 6vw, 5rem);
		}

		h2 {
			font-size: clamp(1.8rem, 4vw, 3rem);
			color: var(--terracotta);
		}

		h3 {
			font-size: clamp(1.5rem, 3vw, 2.2rem);
			color: var(--terracotta);
		}

		p {
			font-family: 'Karla', sans-serif;
			font-size: 1.1rem;
			line-height: 1.6;
		}

		a {
			color: inherit;
			text-decoration: none;
		}

		/* Animations */
		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateY(20px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@keyframes slideDown {
			from {
				opacity: 0;
				transform: translateY(-20px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@keyframes slideUp {
			from {
				opacity: 0;
				transform: translateY(20px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.fade-in {
			animation: fadeIn 0.8s ease forwards;
		}

		.fade-in-delay-1 {
			animation: fadeIn 0.8s ease 0.2s forwards;
			opacity: 0;
		}

		.fade-in-delay-2 {
			animation: fadeIn 0.8s ease 0.4s forwards;
			opacity: 0;
		}

		/* Loader */
		#loader {
			position: fixed;
			inset: 0;
			background: var(--charcoal);
			z-index: 9999;
			display: flex;
			align-items: center;
			justify-content: center;
			transition: transform 0.9s cubic-bezier(0.76, 0, 0.24, 1);
		}

		#loader.hide {
			transform: translateY(-100%);
		}

		.loader-inner {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}

		.loader-name {
			font-family: 'DM Serif Display', serif;
			font-size: clamp(3.5rem, 12vw, 9rem);
			color: var(--cream);
			letter-spacing: -0.02em;
			display: flex;
			overflow: hidden;
		}

		.loader-letter {
			display: inline-block;
			opacity: 0;
			transform: translateY(-60px);
			animation: loaderReveal 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
		}

		.loader-bar-track {
			width: clamp(180px, 40vw, 400px);
			height: 3px;
			background: rgba(249, 246, 241, 0.15);
			border-radius: 999px;
			overflow: hidden;
		}

		.loader-bar {
			height: 100%;
			width: 0%;
			background: var(--copper);
			border-radius: 999px;
			animation: loaderProgress 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.75s forwards;
		}

		@keyframes loaderReveal {
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		@keyframes loaderProgress {
			to { width: 100%; }
		}
	</style>

	<script>
		window.addEventListener('load', () => {
			setTimeout(() => {
				const loader = document.getElementById('loader');
				if (!loader) return;
				loader.classList.add('hide');
				setTimeout(() => loader.remove(), 900);
			}, 1400);
		});
	</script>
</html>
