---
interface Collaborateur {
  nom: string;
  lien?: string;
}

interface Props {
  technos: string[];
  collaborateurs?: Collaborateur[];
  lien?: string;
  github?: string;
}

const { technos, collaborateurs, lien, github } = Astro.props;
---

<aside class="sidebar">
  <section class="sidebar__section">
    <h3 class="sidebar__titre">Technologies</h3>
    <ul class="sidebar__tags">
      {technos.map((t) => <li class="tag">{t}</li>)}
    </ul>
  </section>

  {collaborateurs && collaborateurs.length > 0 && (
    <section class="sidebar__section">
      <h3 class="sidebar__titre">Collaborateurs</h3>
      <ul class="sidebar__liste">
        {collaborateurs.map((c) => (
          <li>
            {c.lien
              ? <a href={c.lien} target="_blank" rel="noopener noreferrer">{c.nom}</a>
              : c.nom
            }
          </li>
        ))}
      </ul>
    </section>
  )}

  {(lien || github) && (
    <section class="sidebar__section">
      <h3 class="sidebar__titre">Liens</h3>
      <ul class="sidebar__liste">
        {lien && (
          <li>
            <a href={lien} target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              Voir le projet
            </a>
          </li>
        )}
        {github && (
          <li>
            <a href={github} target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
              GitHub
            </a>
          </li>
        )}
      </ul>
    </section>
  )}
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 6rem;
  }

  .sidebar__titre {
    font-family: 'Karla', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--charcoal);
    opacity: 0.5;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--sand);
  }

  .sidebar__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag {
    background: var(--sand);
    color: var(--charcoal);
    padding: 0.3em 0.7em;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: 'Karla', sans-serif;
    transition: all 0.3s var(--transition-smooth);
  }

  .tag:hover {
    background: var(--copper);
    color: var(--cream);
  }

  .sidebar__liste {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-family: 'Karla', sans-serif;
  }

  .sidebar__liste a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--charcoal);
    text-decoration: none;
    font-weight: 600;
    padding: 0.4em 0;
    transition: color 0.3s var(--transition-smooth);
  }

  .sidebar__liste a:hover {
    color: var(--copper);
  }

  .sidebar__liste a svg {
    flex-shrink: 0;
    transition: transform 0.3s var(--transition-smooth);
  }

  .sidebar__liste a:hover svg {
    transform: translateX(2px);
  }
</style>
