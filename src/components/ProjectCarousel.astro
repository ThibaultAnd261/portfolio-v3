---
import "../styles/color.css";
import { getCollection } from 'astro:content';

const projets = await getCollection('projets');
const projects = projets
    .filter(projet => projet.data.statut !== 'Hide')
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
    .map((projet) => ({
        title: projet.data.title,   
        description: projet.data.description,
        cover: projet.data.cover || projet.data.image,
        gradient: projet.data.gradient,
        slug: projet.slug,
    }));
---

<section class="carousel-section" id="projects">
    <div class="carousel-header">
        <h2 class="carousel-title">Projets</h2>
        <div class="scroll-indicator">
            <span>Scroll pour explorer</span>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </div>
    </div>

    <div class="carousel-container">
        <div class="carousel-track">
            {projects.map((project, index) => (
                <a href={`/projet/${project.slug}`} class="carousel-panel" data-index={index}>
                    <div class="panel-background" style={`background-image: url(${project.cover}); background-size: cover; background-position: center;`}>
                    </div>
                    <div class="panel-overlay"></div>
                    <div class="panel-content">
                        <span class="panel-number">0{index + 1}</span>
                        <div class="panel-footer">
                            <div class="panel-footer-left">
                                <h3 class="panel-title">{project.title}</h3>
                                <p class="panel-description">{project.description}</p>
                            </div>
                            <div class="panel-cta">
                                <span>Voir le projet</span>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M7 17L17 7M17 7H7M17 7v10"/>
                                </svg>
                            </div>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .carousel-section {
        padding: 3rem 0;
        overflow: hidden;
    }

    .carousel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto 2rem;
        padding: 0 1.5rem;
    }

    .carousel-title {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(2rem, 4vw, 3rem);
        color: var(--charcoal);
    }

    .scroll-indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.9rem;
        color: var(--charcoal);
        opacity: 0.7;
    }

    .scroll-indicator svg {
        animation: bounce-right 1.5s infinite;
    }

    @keyframes bounce-right {
        0%, 100% { transform: translateX(0); }
        50% { transform: translateX(5px); }
    }

    .carousel-container {
        position: relative;
        width: 100%;
        margin: 0 auto;
        overflow-x: auto;
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        cursor: grab;
    }

    .carousel-container::-webkit-scrollbar {
        display: none;
    }

    .carousel-container:active {
        cursor: grabbing;
    }

    .carousel-track {
        display: flex;
        gap: 0;
        padding: 0 1.5rem;
        min-width: min-content;
    }

    .carousel-panel {
        position: relative;
        flex-shrink: 0;
        width: clamp(200px, 25vw, 320px);
        height: clamp(300px, 50vh, 400px);
        border: 4px solid var(--charcoal);
        border-radius: 20px;
        overflow: hidden;
        text-decoration: none;
        color: var(--cream);
        transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        margin-right: -4px;
    }

    .carousel-panel:first-child {
        border-top-left-radius: 20px;
        border-bottom-left-radius: 20px;
    }

    .carousel-panel:last-child {
        border-top-right-radius: 20px;
        border-bottom-right-radius: 20px;
        margin-right: 0;
    }

    .carousel-panel:hover {
        width: clamp(280px, 35vw, 450px);
        z-index: 10;
        transition: width 1.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .panel-background {
        position: absolute;
        inset: 0;
        transition: transform 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .carousel-panel:hover .panel-background {
        transform: scale(1.08);
    }

    /* Number - always visible, rotated 90° in top-left */
    .panel-number {
        font-family: 'DM Serif Display', serif;
        font-size: 2.2rem;
        font-weight: 300;
        line-height: 1;
        color: var(--cream);
        opacity: 0.7;
        position: absolute;
        top: 1.5rem;
        left: 2.5rem;
        transform: rotate(-90deg) translateX(-100%);
        transform-origin: left bottom;
        letter-spacing: 2px;
        z-index: 5;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        transition: opacity 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .carousel-panel:hover .panel-number {
        opacity: 1;
    }

    .panel-footer {
        display: flex;
        flex-direction: column;
    }

    .panel-footer-left {
        display: flex;
        flex-direction: column;
    }

    /* Overlay - always visible as bottom shadow */
    .panel-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(26, 22, 20, 0.9) 0%,
            rgba(26, 22, 20, 0.5) 25%,
            rgba(26, 22, 20, 0.1) 50%,
            transparent 100%
        );
        opacity: 1;
        transition: opacity 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
        z-index: 2;
    }

    .carousel-panel:hover .panel-overlay {
        opacity: 1;
        background: linear-gradient(
            to top,
            rgba(26, 22, 20, 0.97) 0%,
            rgba(26, 22, 20, 0.75) 40%,
            rgba(26, 22, 20, 0.2) 70%,
            transparent 100%
        );
    }

    /* Content - always visible, covers full card so panel-number can be absolute at top */
    .panel-content {
        position: absolute;
        inset: 0;
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        z-index: 3;
    }

    .panel-title {
        font-family: 'DM Serif Display', serif;
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        font-weight: 400;
        margin-bottom: 0.5rem;
        line-height: 1.2;
    }

    /* Description - hidden by default, appears on hover */
    .panel-description {
        font-size: 0.9rem;
        opacity: 0;
        line-height: 1.4;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s cubic-bezier(0.25, 0.1, 0.25, 1) 0.1s,
                    opacity 0.4s cubic-bezier(0.25, 0.1, 0.25, 1) 0.15s;
    }

    .carousel-panel:hover .panel-description {
        max-height: 100px;
        opacity: 0.85;
    }

    .panel-cta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.75rem;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        opacity: 0.7;
        transition: opacity 0.3s ease, gap 0.3s ease;
    }

    .carousel-panel:hover .panel-cta {
        opacity: 1;
    }

    .panel-cta svg {
        transition: transform 0.3s ease;
    }

    .carousel-panel:hover .panel-cta svg {
        transform: translate(3px, -3px);
    }

    /* Mobile adjustments */
    @media (max-width: 767px) {
        .carousel-section {
            padding: 2rem 0;
        }

        .carousel-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .scroll-indicator {
            display: none;
        }

        .carousel-container {
            overflow: visible;
            cursor: default;
        }

        .carousel-track {
            flex-direction: column;
            gap: 8px;
            min-width: unset;
            padding: 0 1.5rem;
        }

        .carousel-panel {
            width: 100%;
            height: 80px;
            border-radius: 12px;
            margin-right: 0;
            background: var(--charcoal);
        }

        .carousel-panel:hover {
            width: 100%;
            transform: none;
            box-shadow: none;
        }

        /* Hide background image on mobile */
        .panel-background {
            display: none;
        }

        /* Hide overlay on mobile (black bg replaces it) */
        .panel-overlay {
            display: none;
        }

        /* Content: centered row covering full card */
        .panel-content {
            inset: 0;
            padding: 0 1.25rem;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }

        /* Number + title in a row on the left */
        .panel-number {
            position: static;
            transform: none;
            transform-origin: initial;
            font-size: 0.85rem;
            letter-spacing: 2px;
            opacity: 0.45;
            margin-bottom: 0;
            margin-right: 0.75rem;
            text-shadow: none;
            flex-shrink: 0;
        }

        .carousel-panel:hover .panel-number {
            opacity: 0.45;
        }

        /* Footer: fills remaining space, row with title left + cta right */
        .panel-footer {
            flex: 1;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            min-width: 0;
        }

        .panel-footer-left {
            min-width: 0;
        }

        .panel-title {
            font-size: 1rem;
            margin-bottom: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .panel-description {
            display: none !important;
        }

        .panel-cta {
            flex-shrink: 0;
            margin-top: 0;
            opacity: 1;
        }
    }

    /* Large screens */
    @media (min-width: 1400px) {
        .carousel-track {
            padding: 0 calc((100vw - 1400px) / 2 + 1.5rem);
        }
    }

    /* Panel entrance animation */
    .panel-animate {
        opacity: 0;
        transform: translateY(20px);
    }

    .panel-animate.is-visible {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .panel-animate.is-visible:hover {
        transform: translateY(0);
    }
</style>

<script>
    // Staggered fade-in animation for panels
    const panels = document.querySelectorAll('.carousel-panel');

    const panelObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                const panel = entry.target as HTMLElement;
                const index = parseInt(panel.dataset.index || '0');
                setTimeout(() => {
                    panel.classList.add('is-visible');
                }, index * 100); // Staggered delay
                panelObserver.unobserve(panel);
            }
        });
    }, { threshold: 0.1 });

    panels.forEach(panel => {
        panel.classList.add('panel-animate');
        panelObserver.observe(panel);
    });

    // Drag to scroll functionality
    const container = document.querySelector('.carousel-container') as HTMLElement;

    if (container) {
        let isDown = false;
        let startX: number;
        let scrollLeft: number;

        container.addEventListener('mousedown', (e) => {
            isDown = true;
            container.style.cursor = 'grabbing';
            startX = e.pageX - container.offsetLeft;
            scrollLeft = container.scrollLeft;
        });

        container.addEventListener('mouseleave', () => {
            isDown = false;
            container.style.cursor = 'grab';
        });

        container.addEventListener('mouseup', () => {
            isDown = false;
            container.style.cursor = 'grab';
        });

        container.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - container.offsetLeft;
            const walk = (x - startX) * 2;
            container.scrollLeft = scrollLeft - walk;
        });

        // Scroll on wheel - only use horizontal swipe, let vertical scroll pass through
        container.addEventListener('wheel', (e) => {
            // Only capture horizontal trackpad gestures
            if (Math.abs(e.deltaX) > Math.abs(e.deltaY) && e.deltaX !== 0) {
                e.preventDefault();
                container.scrollLeft += e.deltaX;
            }
            // Let vertical scroll pass through to scroll the page
        }, { passive: false });
    }
</script>
